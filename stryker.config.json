{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "_comment": "Mutation testing for diff-story. Uses the command runner so Bun executes the suite.",
  "packageManager": "npm",
  "testRunner": "command",
  "commandRunner": {
    "command": "bun --config=bunfig.stryker.toml test"
  },
  "coverageAnalysis": "off",
  "mutate": [
    "src/**/*.ts",
    "!src/io.ts",
    "!src/types.ts",
    "!src/parse-diff.d.ts",
    "!src/**/*.test.ts"
  ],
  "reporters": ["clear-text", "progress", "html"],
  "htmlReporter": {
    "fileName": "reports/mutation/index.html"
  },
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 70
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
