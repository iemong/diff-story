{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "error",
    "style": "error",
    "pedantic": "error"
  },
  "rules": {
    "max-statements": "off",
    "max-lines-per-function": "off"
  },
  "ignorePatterns": ["node_modules", ".stryker-tmp", "coverage", "reports", "dist"]
}
